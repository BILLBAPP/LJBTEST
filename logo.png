:root{
  --paper:#EDE6D3;        /* manila */
  --paper2:#F6F1E2;       /* lighter sheet */
  --paper3:#E2D8BE;       /* darker folder */
  --ink:#1B1C1E;
  --ink-soft:#3E4044;
  --red:#C3272B;          /* stamp ink */
  --red-deep:#9A1B1F;
  --blue:#1E4FBB;         /* ballpoint */
  --line:#B9AE92;
  --gray:#7A7461;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'IBM Plex Sans',sans-serif;background:var(--paper);color:var(--ink-soft);line-height:1.62;font-size:16.5px;overflow-x:hidden;
background-image:radial-gradient(rgba(27,28,30,.04) 1px,transparent 1px);background-size:5px 5px}
h1,h2,h3{font-family:'Allerta Stencil',sans-serif;color:var(--ink);text-transform:uppercase;line-height:1.02;letter-spacing:.01em;text-wrap:balance}
p{text-wrap:pretty}
a{color:var(--red-deep)}
::selection{background:var(--red);color:#fff}
.wrap{max-width:1160px;margin:0 auto;padding:0 24px;position:relative;z-index:2}
.mono{font-family:'IBM Plex Mono',monospace}
section h2{font-size:clamp(1.9rem,4.6vw,3.2rem)}
.atmosphere,.pullband,.qgrid,.stars,.live{display:none}

/* mono micro-labels */
.eyebrow{font-family:'IBM Plex Mono',monospace;font-size:.72rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--ink);display:inline-block;margin-bottom:14px;border:1.5px solid var(--ink);padding:5px 12px;background:var(--paper2)}
.eyebrow::before{content:"■ ";color:var(--red)}

/* rubber stamp */
.stamp{display:inline-block;font-family:'Allerta Stencil',sans-serif;text-transform:uppercase;color:var(--red);border:3px double var(--red);padding:6px 16px;letter-spacing:.14em;transform:rotate(-4deg);opacity:.9;mix-blend-mode:multiply;font-size:.95rem;white-space:nowrap}
.stamp.sm{font-size:.68rem;padding:3px 9px;border-width:2px}
.stamp.ok{color:#1F6B3A;border-color:#1F6B3A}

/* ticker as teletype strip */
.tick{overflow:hidden;background:var(--ink);color:var(--paper);border-bottom:2px solid var(--ink)}
.tick .track{display:flex;white-space:nowrap;width:max-content;animation:mq 26s linear infinite;font-family:'IBM Plex Mono',monospace;font-size:.78rem;letter-spacing:.12em;text-transform:uppercase;padding:8px 0}
.tick .track span{padding:0 22px}
.tick .track i{font-style:normal;color:var(--red);padding:0 4px}
@keyframes mq{to{transform:translateX(-50%)}}
.strip{background:var(--ink);color:var(--paper);font-size:.8rem;padding:8px 0;text-align:center;font-family:'IBM Plex Mono',monospace}
.strip strong{color:#fff}
.strip a{color:#fff}
.strip .dot{color:var(--red);margin:0 10px}

/* nav — folder top edge */
nav{position:sticky;top:0;z-index:60;background:var(--paper2);border-bottom:2px solid var(--ink)}
.navrow{display:flex;align-items:center;justify-content:space-between;padding:11px 0}
.logo{display:flex;align-items:center;gap:13px;text-decoration:none}
.logo img{width:50px;height:50px;border-radius:50%;border:2px solid var(--ink)}
.logo b{font-family:'Allerta Stencil',sans-serif;font-size:1.02rem;color:var(--ink);text-transform:uppercase;line-height:1.05;display:block}
.logo span{font-family:'IBM Plex Mono',monospace;font-size:.6rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gray)}
.navlinks{display:flex;gap:24px;align-items:center}
.navlinks a{text-decoration:none;font-family:'IBM Plex Mono',monospace;font-weight:600;font-size:.78rem;letter-spacing:.1em;text-transform:uppercase;color:var(--ink)}
.navlinks a:not(.btn):hover{color:var(--red);text-decoration:underline;text-underline-offset:4px}

/* buttons — inked blocks */
.btn{display:inline-flex;align-items:center;gap:10px;background:var(--ink);color:var(--paper2);font-family:'Allerta Stencil',sans-serif;text-transform:uppercase;letter-spacing:.08em;font-size:.92rem;padding:14px 26px;text-decoration:none;border:2px solid var(--ink);cursor:pointer;transition:all .15s;position:relative}
.btn:hover{background:var(--red);border-color:var(--red);color:#fff}
.btn.line{background:transparent;color:var(--ink)}
.btn.line:hover{background:var(--ink);color:var(--paper2)}
.btn .arrow{transition:transform .15s}
.btn:hover .arrow{transform:translateX(5px)}

/* ============ HERO — the case file ============ */
.hero{position:relative;z-index:2;padding:64px 0 88px}
.herogrid{display:grid;grid-template-columns:1.2fr 1fr;gap:60px;align-items:start}
.filemeta{font-family:'IBM Plex Mono',monospace;font-size:.78rem;letter-spacing:.08em;text-transform:uppercase;color:var(--gray);border-top:2px solid var(--ink);border-bottom:1px dashed var(--line);padding:10px 0;margin-bottom:26px;display:flex;flex-wrap:wrap;gap:6px 28px}
.filemeta b{color:var(--ink)}
.filemeta .rd{color:var(--red)}
.hero h1{font-size:clamp(2.7rem,6.4vw,5rem);margin:0 0 24px;position:relative}
.hero h1 .underline{position:relative;white-space:nowrap}
.hero h1 .underline::after{content:"";position:absolute;left:0;right:0;bottom:.04em;height:.14em;background:var(--red);opacity:.85;transform:rotate(-.5deg)}
.hero p.lead{font-size:1.08rem;color:var(--ink-soft);max-width:50ch;margin-bottom:14px}
.hero p.louline{font-family:'IBM Plex Mono',monospace;font-size:.95rem;color:var(--ink);max-width:52ch;margin-bottom:30px;border-left:3px solid var(--red);padding-left:14px}
.hero p.louline span{color:var(--gray)}
.herocta{display:flex;gap:16px;flex-wrap:wrap;align-items:center}
.callout{font-family:'IBM Plex Mono',monospace;font-size:.78rem;color:var(--gray)}
.callout b{color:var(--ink)}
.herostamp{position:absolute;top:-8px;right:2%;transform:rotate(7deg);z-index:3}

/* the application sheet (roster) */
.sheet{position:relative;background:var(--paper2);border:2px solid var(--ink);box-shadow:0 14px 34px rgba(27,28,30,.18)}
.sheet::before{content:"";position:absolute;top:-14px;left:34px;width:110px;height:30px;background:rgba(222,214,190,.85);border:1px solid rgba(27,28,30,.2);transform:rotate(-2deg);box-shadow:0 2px 6px rgba(27,28,30,.12)} /* tape */
.sheet .shead{padding:20px 24px 12px;border-bottom:2px solid var(--ink);display:flex;justify-content:space-between;align-items:flex-start;gap:12px}
.sheet .shead h3{font-size:1.05rem}
.sheet .shead p{font-family:'IBM Plex Mono',monospace;font-size:.68rem;letter-spacing:.12em;text-transform:uppercase;color:var(--gray);margin-top:4px}
.count{display:grid;grid-template-columns:repeat(4,1fr);border-bottom:1px dashed var(--line);background:repeating-linear-gradient(0deg,transparent,transparent 26px,rgba(30,79,187,.05) 27px)}
.count div{padding:14px 6px 10px;text-align:center;border-right:1px dashed var(--line)}
.count div:last-child{border-right:none}
.count b{display:block;font-family:'IBM Plex Mono',monospace;font-weight:700;font-size:clamp(1.5rem,2.6vw,2rem);color:var(--ink);line-height:1}
.count span{font-family:'IBM Plex Mono',monospace;font-size:.58rem;letter-spacing:.22em;text-transform:uppercase;color:var(--gray)}
.rrow{display:flex;justify-content:space-between;align-items:center;padding:14px 22px;border-bottom:1px dashed var(--line);gap:10px}
.rrow:last-of-type{border-bottom:none}
.rrow .d b{display:block;font-family:'IBM Plex Mono',monospace;font-weight:700;color:var(--ink);font-size:.92rem;text-transform:uppercase}
.rrow .d span{font-family:'IBM Plex Mono',monospace;font-size:.72rem;color:var(--gray)}
.seats{font-family:'IBM Plex Mono',monospace;font-size:.64rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;padding:4px 8px;color:var(--gray);border:1.5px solid var(--line);white-space:nowrap;background:var(--paper2)}
.seats.low{color:var(--red);border:2px double var(--red);transform:rotate(-2deg);background:none;font-family:'Allerta Stencil',sans-serif}
.rrow>a{font-family:'Allerta Stencil',sans-serif;font-size:.78rem;text-transform:uppercase;text-decoration:none;color:var(--paper2);background:var(--ink);padding:8px 15px;white-space:nowrap;transition:background .15s}
.rrow>a:hover{background:var(--red)}
.sheet footer{padding:12px 22px;border-top:2px solid var(--ink);text-align:center;background:var(--paper3)}
.sheet footer a{font-family:'IBM Plex Mono',monospace;font-weight:600;font-size:.78rem;letter-spacing:.08em;text-transform:uppercase}
.roster{position:relative;background:var(--paper2);border:2px solid var(--ink)}
.roster header{padding:18px 22px;border-bottom:2px solid var(--ink)}
.roster header h3{font-size:1rem}
.roster header p{font-family:'IBM Plex Mono',monospace;font-size:.68rem;color:var(--gray)}

/* ============ stats — inventory line ============ */
.statband{padding:74px 0 54px}
.statrow{display:grid;grid-template-columns:repeat(4,1fr);gap:0;border:2px solid var(--ink);background:var(--paper2)}
.stat{padding:24px 22px 18px;border-right:1px dashed var(--line);position:relative}
.stat:last-child{border-right:none}
.stat::before{content:"NO. 0" counter(statn);counter-increment:statn;font-family:'IBM Plex Mono',monospace;font-size:.58rem;letter-spacing:.2em;color:var(--gray);position:absolute;top:8px;right:12px}
.statrow{counter-reset:statn}
.stat b{display:block;font-family:'Allerta Stencil',sans-serif;font-size:clamp(2rem,4vw,3rem);line-height:1;color:var(--ink)}
.stat b i{font-style:normal;color:var(--red)}
.stat span{display:block;margin-top:8px;font-family:'IBM Plex Mono',monospace;font-size:.64rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gray)}

/* ============ sections ============ */
.band{position:relative;z-index:2;padding:92px 0}
.band.dark{background:var(--ink);color:#CFC9B8}
.band.dark h2{color:var(--paper)}
.band.dark .sechead p{color:#9A9482}
.band.dark .eyebrow{background:var(--ink);color:var(--paper);border-color:var(--paper)}
.sechead{max-width:740px;margin-bottom:52px}
.sechead p{margin-top:14px;color:var(--gray);font-size:1.02rem}

/* folder tab section headers */
.tabhead{display:flex;align-items:flex-end;gap:0;margin-bottom:0}
.tabhead .tab{font-family:'Allerta Stencil',sans-serif;text-transform:uppercase;font-size:1rem;background:var(--paper3);border:2px solid var(--ink);border-bottom:none;padding:10px 26px 8px;clip-path:polygon(0 100%,0 12px,12px 0,calc(100% - 16px) 0,100% 100%)}

/* ============ steps — checklist ============ */
.stepgrid{display:block;border:2px solid var(--ink);background:var(--paper2)}
.step{display:grid;grid-template-columns:64px 1fr auto;gap:24px;align-items:start;padding:28px 26px;border-bottom:1px dashed var(--line)}
.step:last-child{border-bottom:none}
.step .num{font-family:'IBM Plex Mono',monospace;font-weight:700;font-size:1rem;color:var(--paper2);background:var(--ink);width:44px;height:44px;display:flex;align-items:center;justify-content:center;margin-top:4px}
.step .tag{display:none}
.step h3{font-size:1.25rem;margin-bottom:8px;font-family:'IBM Plex Sans',sans-serif;font-weight:700;text-transform:none;letter-spacing:0}
.step p{font-size:.97rem;max-width:62ch}
.step .chk{font-family:'Allerta Stencil',sans-serif;color:var(--red);font-size:1.5rem;transform:rotate(-6deg);align-self:center}

/* ============ courses — filed lists ============ */
.coursecols{display:grid;grid-template-columns:repeat(3,1fr);gap:26px;align-items:start}
.ccol{background:var(--paper2);border:2px solid var(--ink);position:relative}
.ccol::after{content:"";position:absolute;top:10px;bottom:10px;left:8px;border-left:1px solid rgba(195,39,43,.35)} /* margin rule */
.ccol header{padding:16px 22px 12px 26px;border-bottom:2px solid var(--ink)}
.ccol header h3{font-size:.98rem}
.ccol header p{font-family:'IBM Plex Mono',monospace;font-size:.64rem;color:var(--gray);margin-top:4px;letter-spacing:.14em;text-transform:uppercase}
.ccol ul{list-style:none;background:repeating-linear-gradient(0deg,transparent,transparent 43px,rgba(27,28,30,.07) 44px)}
.ccol li{padding:11px 22px 11px 26px;font-size:.92rem;display:flex;justify-content:space-between;gap:10px;min-height:44px}
.ccol li b{font-weight:600;color:var(--ink)}
.ccol li b::before{content:"☐ ";color:var(--gray)}
.ccol.featured li b::before{content:"☑ ";color:var(--red)}
.ccol li span{font-family:'IBM Plex Mono',monospace;color:var(--gray);font-size:.8rem;white-space:nowrap}
.ccol.featured{outline:2px solid var(--ink);outline-offset:4px}
.ccol.featured header h3{color:var(--red-deep)}
.ccol .stamp{position:absolute;bottom:-14px;right:14px}

/* ============ packages — fee schedule ============ */
.pkgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:26px;align-items:stretch}
.pk{position:relative;background:var(--paper);color:var(--ink-soft);border:2px solid var(--paper);padding:30px 28px;display:flex;flex-direction:column}
.band.dark .pk{background:var(--paper2);border-color:var(--paper2)}
.pk h3{font-size:1.05rem;margin-bottom:10px}
.pk .price{font-family:'Allerta Stencil',sans-serif;font-size:3rem;color:var(--ink);line-height:1}
.pk .was{font-family:'IBM Plex Mono',monospace;font-size:.85rem;color:var(--gray);text-decoration:line-through;margin-left:10px}
.pk .save{display:inline-block;margin-left:10px;font-family:'IBM Plex Mono',monospace;font-size:.64rem;font-weight:600;letter-spacing:.12em;color:var(--red);border:2px double var(--red);padding:3px 8px;text-transform:uppercase;transform:rotate(-2deg)}
.pk p{font-size:.92rem;margin:14px 0 22px;flex:1}
.pk .btn{justify-content:center}
.pk.best{outline:3px double var(--red);outline-offset:5px}
.pk .best-tag{position:absolute;top:-14px;right:18px;background:var(--red);color:#fff;font-family:'Allerta Stencil',sans-serif;font-size:.66rem;letter-spacing:.14em;text-transform:uppercase;padding:6px 14px;transform:rotate(2deg)}
.pk .inc{list-style:none;margin:4px 0 22px;flex:1}
.pk .inc li{padding:7px 0;font-size:.9rem;border-bottom:1px dashed var(--line)}
.pk .inc li:last-child{border-bottom:none}
.pk .inc li::before{content:"— "}
.pk .inc b{color:var(--ink);font-weight:700}
.bandnote{text-align:center;margin-top:32px;font-family:'IBM Plex Mono',monospace;font-size:.8rem;color:#9A9482}
.bandnote a{color:var(--paper)}
.newtag{display:inline-block;font-family:'IBM Plex Mono',monospace;font-size:.58rem;font-weight:600;letter-spacing:.16em;text-transform:uppercase;color:var(--red);border:1.5px solid var(--red);padding:2px 7px;margin-left:10px;vertical-align:middle}

/* ============ exhibits (testimonials) ============ */
.txtgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:26px;align-items:start}
.phone{background:var(--paper2);border:2px solid var(--ink);padding:22px 22px 16px;position:relative;transform:rotate(-.6deg)}
.phone:nth-child(2){transform:rotate(.8deg)}
.phone:nth-child(3){transform:rotate(-.3deg)}
.phone::before{content:"";position:absolute;top:-12px;left:50%;transform:translateX(-50%) rotate(1deg);width:96px;height:26px;background:rgba(222,214,190,.9);border:1px solid rgba(27,28,30,.18);box-shadow:0 2px 5px rgba(27,28,30,.1)}
.phone .from{font-family:'IBM Plex Mono',monospace;font-size:.64rem;letter-spacing:.16em;text-transform:uppercase;color:var(--gray);border-bottom:1px dashed var(--line);padding-bottom:9px;margin-bottom:12px}
.phone .from::before{content:"EXHIBIT " counter(exh,upper-alpha) " — ";counter-increment:exh;color:var(--red)}
.txtgrid{counter-reset:exh}
.bubble{font-size:.95rem;color:var(--ink-soft);margin-bottom:10px;font-style:italic}
.bubble.me{font-style:normal;font-family:'IBM Plex Mono',monospace;font-size:.8rem;color:var(--ink);border-top:1px dashed var(--line);padding-top:9px}
.bubble.me::before{content:"LOU: ";color:var(--red);font-weight:700}
.phone .meta{font-family:'IBM Plex Mono',monospace;font-size:.62rem;color:var(--gray);text-align:right}

/* ============ about — personnel record ============ */
.aboutgrid{display:grid;grid-template-columns:1fr 1.15fr;gap:60px;align-items:center}
.louframe{position:relative;background:var(--paper2);border:2px solid var(--ink);aspect-ratio:4/5;display:flex;align-items:center;justify-content:center;overflow:visible;box-shadow:0 12px 30px rgba(27,28,30,.15)}
.louframe::before{content:"";position:absolute;top:-16px;left:24px;width:100px;height:28px;background:rgba(222,214,190,.9);border:1px solid rgba(27,28,30,.18);transform:rotate(-2deg)}
.louframe::after{content:"PERSONNEL PHOTO — ATTACH HERE";position:absolute;bottom:14px;left:0;right:0;text-align:center;font-family:'IBM Plex Mono',monospace;font-size:.58rem;letter-spacing:.2em;color:var(--gray)}
.louframe span{font-family:'IBM Plex Mono',monospace;color:var(--gray);text-transform:uppercase;letter-spacing:.16em;font-size:.72rem;text-align:center;padding:0 20px}
.louframe img.ph{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:grayscale(1) contrast(1.06) sepia(.14)}
.badgefloat{position:absolute;bottom:-24px;right:-24px;width:112px;height:112px;border-radius:50%;border:2px solid var(--ink);background:#fff;box-shadow:0 8px 20px rgba(27,28,30,.25)}
.creds{margin-top:26px;border:2px solid var(--ink);background:var(--paper2)}
.creds{display:grid;grid-template-columns:1fr 1fr;gap:0}
.creds div{padding:14px 18px;font-size:.84rem;color:var(--gray);border-right:1px dashed var(--line);border-bottom:1px dashed var(--line)}
.creds div:nth-child(2n){border-right:none}
.creds div:nth-child(n+3){border-bottom:none}
.creds div b{display:block;color:var(--ink);font-family:'IBM Plex Mono',monospace;font-weight:700;text-transform:uppercase;font-size:.95rem}

/* ============ final — the stamp moment ============ */
.final{position:relative;z-index:2;padding:96px 0}
.finalglass{position:relative;max-width:860px;margin:0 auto;background:var(--paper2);border:2px solid var(--ink);padding:64px 52px;box-shadow:0 18px 44px rgba(27,28,30,.18)}
.finalglass::before{content:"FORM LJB-01 · REV 2026";position:absolute;top:12px;right:16px;font-family:'IBM Plex Mono',monospace;font-size:.58rem;letter-spacing:.16em;color:var(--gray)}
.finalglass .eyebrow{background:var(--paper2)}
.finalglass h2{font-size:clamp(2rem,4.8vw,3.4rem)}
.finalglass p{color:var(--gray);margin:14px 0 30px;max-width:54ch}
.final .ctas{display:flex;gap:16px;flex-wrap:wrap}
.final .bigstamp{position:absolute;bottom:26px;right:30px;transform:rotate(-9deg);font-size:1.4rem;padding:10px 22px;border-width:4px}

/* footer — end of file */
footer.site{position:relative;z-index:2;background:var(--ink);color:#9A9482;padding:54px 0 0;font-size:.88rem}
.fgrid{display:grid;grid-template-columns:2fr 1fr 1fr;gap:44px;padding-bottom:38px}
footer.site h4{font-family:'IBM Plex Mono',monospace;color:var(--paper);text-transform:uppercase;font-size:.78rem;letter-spacing:.18em;margin-bottom:14px}
footer.site a{color:#CFC9B8;text-decoration:none;display:block;padding:3px 0;font-family:'IBM Plex Mono',monospace;font-size:.82rem}
footer.site a:hover{color:var(--red)}
.flogo{display:flex;align-items:center;gap:14px;margin-bottom:16px}
.flogo img{width:52px;height:52px;border-radius:50%;border:2px solid var(--paper)}
.bigmark{font-family:'IBM Plex Mono',monospace;font-size:.72rem;letter-spacing:.5em;color:#6B6656;text-align:center;padding:8px 0 0;text-transform:uppercase}
.copyright{border-top:1px dashed #55503F;padding:16px 0 18px;font-size:.72rem;text-align:center;color:#6B6656;font-family:'IBM Plex Mono',monospace}

/* sticky book */
.stickybook{position:fixed;right:16px;bottom:16px;z-index:70;background:var(--red);color:#fff;font-family:'Allerta Stencil',sans-serif;font-size:.8rem;text-transform:uppercase;letter-spacing:.08em;text-decoration:none;padding:13px 18px;border:2px solid var(--ink);box-shadow:0 8px 20px rgba(27,28,30,.3)}
.stickybook:hover{background:var(--red-deep);color:#fff}

/* reveal */
.rv{opacity:0;transform:translateY(14px);transition:opacity .5s ease,transform .5s ease}
.rv.on{opacity:1;transform:none}
.rv.d1{transition-delay:.06s}.rv.d2{transition-delay:.12s}

/* ============ interior pages ============ */
.pagehero{position:relative;z-index:2;padding:64px 0 56px;border-bottom:2px solid var(--ink)}
.pagehero h1{font-size:clamp(2.1rem,5vw,3.6rem);margin:6px 0 16px}
.pagehero p{max-width:62ch;color:var(--ink-soft);font-size:1.02rem}
.subnav{position:relative;z-index:2;margin-top:28px;display:flex;flex-wrap:wrap;gap:12px}
.subnav a{font-family:'IBM Plex Mono',monospace;font-size:.72rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;text-decoration:none;color:var(--ink);border:1.5px solid var(--ink);background:var(--paper2);padding:9px 16px;transition:all .12s}
.subnav a:hover{background:var(--ink);color:var(--paper2)}
.pricewrap{background:var(--paper2);border:2px solid var(--ink);overflow:hidden}
table.prices{width:100%;border-collapse:collapse;font-size:.93rem}
table.prices th{font-family:'IBM Plex Mono',monospace;text-transform:uppercase;letter-spacing:.14em;font-size:.68rem;color:var(--paper2);text-align:left;padding:13px 22px;background:var(--ink)}
table.prices td{padding:13px 22px;border-bottom:1px dashed var(--line);vertical-align:top}
table.prices tr:last-child td{border-bottom:none}
table.prices b{color:var(--ink);font-weight:600}
table.prices .cat{font-family:'Allerta Stencil',sans-serif;font-size:.8rem;letter-spacing:.14em;text-transform:uppercase;color:var(--red-deep);border-bottom:2px solid var(--ink);padding-top:24px}
table.prices .price{font-family:'IBM Plex Mono',monospace;font-weight:700;color:var(--ink);white-space:nowrap}
table.prices small{color:var(--gray)}
.tablenote{font-family:'IBM Plex Mono',monospace;font-size:.74rem;color:var(--gray);margin-top:12px}
.pathflow{display:grid;grid-template-columns:repeat(5,1fr);gap:0;counter-reset:path;border:2px solid var(--ink);background:var(--paper2)}
.pnode{position:relative;padding:26px 20px;border-right:1px dashed var(--line)}
.pnode:last-child{border-right:none}
.pnode::before{counter-increment:path;content:"STEP 0" counter(path);font-family:'IBM Plex Mono',monospace;font-weight:700;font-size:.66rem;letter-spacing:.2em;color:var(--gray);display:block;margin-bottom:10px}
.pnode.hot::before{color:var(--red)}
.pnode h3{font-size:.95rem;margin-bottom:8px}
.pnode p{font-size:.82rem;color:var(--gray)}
.pnode .pay{display:inline-block;margin-top:10px;font-family:'IBM Plex Mono',monospace;font-size:.64rem;letter-spacing:.1em;text-transform:uppercase;color:var(--red-deep);border-top:2px solid var(--red);padding:5px 0 0}
.trackgrid{display:grid;grid-template-columns:repeat(2,1fr);gap:28px}
.track{position:relative;background:var(--paper2);border:2px solid var(--ink);padding:28px 26px}
.track .who{display:inline-block;font-family:'IBM Plex Mono',monospace;font-size:.62rem;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:var(--paper2);background:var(--ink);padding:5px 11px;margin-bottom:14px}
.track h3{font-size:clamp(1.1rem,2vw,1.4rem);margin-bottom:10px}
.track>p{font-size:.94rem;margin-bottom:16px}
.track ul{list-style:none;margin-bottom:22px}
.track li{padding:9px 0;border-bottom:1px dashed var(--line);font-size:.9rem}
.track li b{color:var(--ink);font-weight:600}
.track li b::before{content:"☐ ";color:var(--gray)}
.track li span{display:block;font-size:.78rem;color:var(--gray);padding-left:22px}
.track.wide{grid-column:1/-1}
.faqlist{max-width:880px;margin:0 auto;border:2px solid var(--ink);background:var(--paper2)}
.faq{border-bottom:1px dashed var(--line)}
.faq:last-child{border-bottom:none}
.faq summary{list-style:none;cursor:pointer;padding:20px 56px 20px 24px;font-family:'IBM Plex Sans',sans-serif;font-weight:700;font-size:1.05rem;color:var(--ink);position:relative;text-wrap:balance}
.faq summary::before{content:"Q. ";font-family:'IBM Plex Mono',monospace;color:var(--red)}
.faq summary::-webkit-details-marker{display:none}
.faq summary::after{content:"+";position:absolute;right:22px;top:50%;transform:translateY(-50%);font-size:1.6rem;color:var(--red)}
.faq[open] summary::after{content:"–"}
.faq .a{padding:0 24px 22px 24px;font-size:.95rem}
.faq .a p:first-child::before{content:"A. ";font-family:'IBM Plex Mono',monospace;color:var(--gray);font-weight:700}
.faq .a p+p{margin-top:10px}
.faq .a b{color:var(--ink)}
.faqnote{max-width:880px;margin:24px auto 0;font-family:'IBM Plex Mono',monospace;font-size:.72rem;color:var(--gray)}
.contactgrid{display:grid;grid-template-columns:1fr 1.15fr;gap:36px;align-items:start}
.ccard{background:var(--paper2);border:2px solid var(--ink);padding:26px}
.ccard h3{font-size:1.1rem;margin-bottom:14px}
.crow{display:block;padding:12px 0;border-bottom:1px dashed var(--line);font-size:.93rem}
.crow:last-child{border-bottom:none}
.crow .ic{display:none}
.crow b{display:block;color:var(--red-deep);font-family:'IBM Plex Mono',monospace;text-transform:uppercase;font-size:.64rem;letter-spacing:.2em;margin-bottom:3px}
.mapframe{border:2px solid var(--ink);overflow:hidden;margin-top:26px}
.mapframe iframe{display:block;width:100%;height:380px;border:0;filter:grayscale(1) sepia(.18) contrast(1.02)}
.cform label{display:block;font-family:'IBM Plex Mono',monospace;font-size:.64rem;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:var(--gray);margin:16px 0 5px}
.cform input,.cform select,.cform textarea{width:100%;padding:12px 13px;border:none;border-bottom:2px solid var(--ink);background:transparent;font-family:'IBM Plex Mono',monospace;font-size:.92rem;color:var(--blue)}
.cform input:focus,.cform select:focus,.cform textarea:focus{outline:none;border-bottom-color:var(--red);background:rgba(255,255,255,.4)}
.cform .btn{margin-top:22px}
.timeline{max-width:840px;margin:0 auto;border-left:2px solid var(--ink);padding-left:36px}
.tl{position:relative;padding-bottom:34px}
.tl:last-child{padding-bottom:0}
.tl::before{content:"";position:absolute;left:-43px;top:7px;width:12px;height:12px;background:var(--red)}
.tl .when{font-family:'IBM Plex Mono',monospace;font-size:.68rem;font-weight:600;letter-spacing:.22em;text-transform:uppercase;color:var(--red-deep)}
.tl h3{font-size:1.15rem;margin:4px 0 6px}
.tl p{font-size:.94rem}

/* mobile */
.menu-btn{display:none;background:var(--ink);color:var(--paper2);border:2px solid var(--ink);padding:9px 13px;cursor:pointer;font-family:'IBM Plex Mono',monospace;font-size:.72rem;letter-spacing:.1em;text-transform:uppercase}
@media(max-width:960px){
  .menu-btn{display:inline-flex;align-items:center;gap:8px}
  .navlinks{display:none;position:absolute;top:100%;left:0;right:0;flex-direction:column;align-items:stretch;gap:0;background:var(--paper2);border-bottom:2px solid var(--ink);box-shadow:0 20px 40px rgba(27,28,30,.18);padding:8px 24px 20px}
  .navlinks.open{display:flex}
  .navlinks a{padding:13px 0;border-bottom:1px dashed var(--line);font-size:.95rem}
  .navlinks .btn{margin-top:14px;justify-content:center}
  .herogrid,.aboutgrid,.contactgrid{grid-template-columns:1fr}
  .hero{padding:44px 0 60px}
  .herostamp{position:static;display:inline-block;margin-bottom:16px}
  .statrow{grid-template-columns:1fr 1fr}
  .stat:nth-child(2){border-right:none}
  .stat:nth-child(-n+2){border-bottom:1px dashed var(--line)}
  .step{grid-template-columns:44px 1fr;gap:16px;padding:24px 18px}
  .step .chk{display:none}
  .coursecols,.pkgrid,.txtgrid{grid-template-columns:1fr}
  .phone,.phone:nth-child(2),.phone:nth-child(3){transform:none}
  .fgrid{grid-template-columns:1fr}
  .badgefloat{width:88px;height:88px;bottom:-12px;right:-8px}
  .pathflow{grid-template-columns:1fr}
  .pnode{border-right:none;border-bottom:1px dashed var(--line)}
  .pnode:last-child{border-bottom:none}
  .trackgrid{grid-template-columns:1fr}
  .pricewrap{overflow-x:auto}
  table.prices{min-width:560px}
  .final .bigstamp{position:static;display:inline-block;margin-top:18px;transform:rotate(-4deg)}
}
@media(prefers-reduced-motion:reduce){
  html{scroll-behavior:auto}
  .rv{opacity:1;transform:none;transition:none}
  .tick .track{animation:none}
}
